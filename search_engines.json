{
  "engines": [
    {
      "name": "DuckDuckGo",
      "url_template": "https://html.duckduckgo.com/html/?q={query}",
      "method": "GET",
      "link_selector": "a.result__a",
      "exclude_domain_in_href": "duckduckgo.com",
      "priority": 1
    },
    {
      "name": "Brave",
      "url_template": "https://search.brave.com/search?q={query}",
      "method": "GET",
      "link_selector": "a[href^='http']:not([href*='brave.com'])",
      "exclude_domain_in_href": "brave.com",
      "priority": 2
    },
    {
      "name": "Startpage",
      "url_template": "https://www.startpage.com/sp/search?query={query}&cat=web",
      "method": "GET",
      "link_selector": "a[href^='http']:not([href*='startpage.com'])",
      "exclude_domain_in_href": "startpage.com",
      "priority": 3
    },
    {
      "name": "Google",
      "url_template": "https://www.google.com/search?q={query}&num=20&hl=en",
      "method": "GET",
      "link_selector": "div.g a[href]",
      "exclude_domain_in_href": "google.com",
      "priority": 4
    }
  ],
  "banned_domains": [
    "pinterest.com", "instagram.com", "tiktok.com",
    "facebook.com", "twitter.com", "x.com",
    "amazon.com", "ebay.com", "aliexpress.com",
    "youtube.com", "youtu.be", "vimeo.com",
    "khanacademy.org"
  ],
  "_priority_sources_note": "priority_sources cũ (leftover từ rulesworldsimulator: orionsarm.com, worldanvil.com, projectrho.com...) đã bị xoá — đó là nguồn xenobiology/speculative fiction, sai ngữ cảnh cho mọi module ở đây (Module 2 dùng SOURCE_PRIORITY riêng trong config.py; Module 3/4 không dùng field này). is_priority_source hiện không được downstream nào tiêu thụ; để trống cho tới khi có module thật sự cần.",
  "priority_sources": []
}
